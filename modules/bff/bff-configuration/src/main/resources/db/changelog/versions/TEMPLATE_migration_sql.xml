<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        TEMPLATE pour nouvelle version avec SQL pur

        Instructions:
        1. Copier ce fichier
        2. Renommer: v{VERSION}-{description}.xml
        3. Créer le script SQL correspondant dans db/changelog/sql/
        4. Remplacer les placeholders ci-dessous
        5. Ajouter l'include dans db.changelog-master.xml
    -->

    <changeSet id="v{VERSION}-{description}" author="{ton-nom}">
        <comment>{Description détaillée de la migration}</comment>
        <sqlFile
            path="db/changelog/sql/V{VERSION}__{description}.sql"
            relativeToChangelogFile="false"
            splitStatements="true"
            stripComments="false"/>
        <rollback>
            <!-- Instructions SQL pour annuler la migration -->
            <!-- Exemple: DROP TABLE IF EXISTS nouvelle_table CASCADE; -->
        </rollback>
    </changeSet>

</databaseChangeLog>

