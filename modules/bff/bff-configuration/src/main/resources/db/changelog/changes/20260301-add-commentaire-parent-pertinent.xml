<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="add-commentaire-parent-and-pertinent-flag" author="paytogether">
        <comment>
            Ajout des colonnes pour la gestion des commentaires parents/réponses et du flag de pertinence
        </comment>

        <!-- Ajout de la colonne commentaire_parent_uuid -->
        <addColumn tableName="commentaire">
            <column name="commentaire_parent_uuid" type="uuid">
                <constraints nullable="true"/>
            </column>
        </addColumn>

        <!-- Ajout de la colonne est_pertinent avec valeur par défaut false -->
        <addColumn tableName="commentaire">
            <column name="est_pertinent" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <!-- Ajout de la contrainte de clé étrangère pour commentaire_parent_uuid -->
        <addForeignKeyConstraint
                baseTableName="commentaire"
                baseColumnNames="commentaire_parent_uuid"
                constraintName="fk_commentaire_parent"
                referencedTableName="commentaire"
                referencedColumnNames="uuid"
                onDelete="CASCADE"/>

        <!-- Ajout d'un index pour améliorer les performances de recherche des réponses -->
        <createIndex indexName="idx_commentaire_parent_uuid" tableName="commentaire">
            <column name="commentaire_parent_uuid"/>
        </createIndex>

        <rollback>
            <dropIndex indexName="idx_commentaire_parent_uuid" tableName="commentaire"/>
            <dropForeignKeyConstraint baseTableName="commentaire" constraintName="fk_commentaire_parent"/>
            <dropColumn tableName="commentaire" columnName="est_pertinent"/>
            <dropColumn tableName="commentaire" columnName="commentaire_parent_uuid"/>
        </rollback>
    </changeSet>

</databaseChangeLog>

