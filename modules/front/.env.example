# ===============================================
# Configuration Frontend - PayToGether
# ===============================================

# URL de l'API en production
# Utilisée quand l'application est buildée pour la production
VITE_API_BASE_URL=https://devbff.dealtogether.ca/api

# URL de l'API en développement
# Utilisée quand l'application tourne en mode dev (npm run dev)
VITE_API_DEV_BASE_URL=http://localhost:8080/api

# ===============================================
# Notes importantes :
# - En mode dev (npm run dev) : utilise VITE_API_DEV_BASE_URL
# - En mode prod (npm run build) : utilise VITE_API_BASE_URL
# - Copier ce fichier vers .env et ajuster les valeurs
# ===============================================

# ===============================================
# Configuration Square Payment
# ===============================================
# Pour obtenir ces valeurs, créez un compte sur https://developer.squareup.com/

# Application ID Square (Sandbox ou Production)
VITE_SQUARE_APPLICATION_ID=sandbox-sq0idb-O3zqd445poa7dwnZRMFVfg

# Location ID Square
VITE_SQUARE_LOCATION_ID=LE711KC8GTN39

# Environnement (SANDBOX ou PRODUCTION)
VITE_SQUARE_ENVIRONMENT=SANDBOX

# Note:
# - Pour le développement, utilisez les clés Sandbox
# - Pour la production, remplacez par les clés Production
# - Ne commitez JAMAIS ces clés dans le repository
# ===============================================
